# Build-time configuration. Copy to .env for local builds, or set these in your
# host (e.g. Vercel project env vars). VITE_-prefixed vars are bundled into the
# client; do NOT put secrets here.

# Collapse multiple due-date changes on the SAME task within N minutes into one
# (a burst of edits is usually a typo correction, not real rescheduling).
# Default 10. Set 0 to disable.
VITE_RESCHEDULE_DEDUP_MIN=10

# Local dev/test ONLY — never bundled (no VITE_ prefix). Used by the live
# integration test (tests/live.integration.test.ts) and ad-hoc scripts.
# TODOIST_API_TOKEN=your_token_here
